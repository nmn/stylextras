{
  "name": "stylextras",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@stylexjs/eslint-plugin": "0.18.3",
    "@types/bun": "^1.2.3",
    "@typescript-eslint/parser": "7.2.0",
    "eslint": "8.57.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  },
  "scripts": {
    "build": "bun run build:website",
    "build:website": "bun run --filter website build",
    "lint:stylex": "eslint \"packages/ui/src/**/*.{ts,tsx}\"",
    "test": "bun run test:ui && bun run test:website",
    "test:ui": "vitest run packages/ui/test",
    "test:website": "bun run --filter website test",
    "test:e2e": "bun run --filter website test:e2e",
    "format": "biome format --write ."
  },
  "workspaces": [
    "apps/*",
    "tools/*",
    "packages/*"
  ]
}
